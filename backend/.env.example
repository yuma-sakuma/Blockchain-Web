DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=blockchain_vin

# Blockchain Config - ใส่ค่าจาก Ganache ของตัวเอง
GANACHE_RPC_URL=http://127.0.0.1:7545
ADMIN_PRIVATE_KEY=<your_ganache_private_key>

# Contract Addresses - จะถูกอัปเดตอัตโนมัติเมื่อรัน deploy script
# npx hardhat run scripts/deploy.ts --network ganache
VEHICLE_NFT_ADDRESS=<auto-filled after deploy>
VEHICLE_REGISTRY_ADDRESS=<auto-filled after deploy>
VEHICLE_LIFECYCLE_ADDRESS=<auto-filled after deploy>
VEHICLE_LIEN_ADDRESS=<auto-filled after deploy>
VEHICLE_CONSENT_ADDRESS=<auto-filled after deploy>
