GANACHE_RPC_URL=http://127.0.0.1:7545

# --- Ganache / Network Private Keys ---
# Copy private keys from Ganache and paste them here.
# The Deployer pays for the contract deployments.
# The others are used to derive public addresses and assign on-chain roles.
DEPLOYER_PRIVATE_KEY=0x_your_ganache_private_key_0
MANUFACTURER_PRIVATE_KEY=0x_your_ganache_private_key_1
DEALER_PRIVATE_KEY=0x_your_ganache_private_key_2
DLT_OFFICER_PRIVATE_KEY=0x_your_ganache_private_key_3
CONSUMER_PRIVATE_KEY=0x_your_ganache_private_key_4
LENDER_PRIVATE_KEY=0x_your_ganache_private_key_5
INSURER_PRIVATE_KEY=0x_your_ganache_private_key_6
SERVICE_PROVIDER_PRIVATE_KEY=0x_your_ganache_private_key_7
INSPECTOR_PRIVATE_KEY=0x_your_ganache_private_key_8
